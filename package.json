{
  "name": "modelhub-desktop",
  "version": "1.0.0",
  "description": "本地 LLM 模型管理器 — Local LLM Model Manager Desktop App",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev"
  },
  "keywords": ["llm", "ollama", "model-manager", "electron", "desktop"],
  "author": "ZSeven-W",
  "license": "MIT",
  "dependencies": {
    "electron": "^28.2.0",
    "express": "^4.18.2",
    "sql.js": "^1.10.2"
  },
  "devDependencies": {
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.zseven.modelhub-desktop",
    "productName": "ModelHub-Desktop",
    "directories": {
      "output": "dist"
    },
    "mac": {
      "category": "public.app-category.developer-tools",
      "target": ["dmg"]
    },
    "files": [
      "**/*",
      "!node_modules/**/*",
      "!dist/**/*"
    ],
    "extraResources": [
      {
        "from": "node_modules/electron/dist/Electron.app",
        "to": "Electron.app"
      }
    ]
  }
}
